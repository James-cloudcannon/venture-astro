---
import CustomSection from "@builders/custom-section/CustomSection.astro";
import Heading from "@core-elements/heading/Heading.astro";
import Text from "@core-elements/text/Text.astro";

const {
  heading = "",
  bodyContent = "",

  colorScheme = "inherit",
  backgroundColor,
  class: className,
  useDefaultEditableBinding = false,
  _component,
  ...htmlAttributes
} = Astro.props;
---

<CustomSection
  class:list={["open-text", className]}
  maxContentWidth="lg"
  paddingHorizontal="xl"
  paddingVertical="4xl"
  colorScheme={colorScheme}
  backgroundColor={backgroundColor}
  useDefaultEditableBinding={useDefaultEditableBinding}
  {...htmlAttributes}
>
  <Heading level="h2" data-prop="heading">{heading}</Heading>
  <Text data-prop="bodyContent" text={bodyContent} />
</CustomSection>

<style is:global>
  @layer page-sections {
    .open-text {
      .text-inner {
        h2,
        h3,
        h4,
        h5,
        h6 {
          margin-top: var(--spacing-2xl);
          margin-bottom: var(--spacing-sm);
          font-family: var(--font-headings);
          color: var(--color-text-strong);
        }

        h2 {
          font-size: var(--font-size-heading-lg);
        }

        h3 {
          font-size: var(--font-size-heading-md);
        }

        h4 {
          font-size: var(--font-size-heading-sm);
        }

        p {
          margin-block: var(--spacing-md);
          line-height: 1.7;
        }

        ul,
        ol {
          margin-block: var(--spacing-md);
          padding-inline-start: var(--spacing-xl);
        }

        li {
          margin-block: var(--spacing-xs);
        }

        a {
          color: var(--color-link);
          text-decoration: underline;
        }
      }
    }
  }
</style>
