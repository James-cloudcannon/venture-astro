---
import CustomSection from "@builders/custom-section/CustomSection.astro";
import Heading from "@core-elements/heading/Heading.astro";
import SimpleText from "@core-elements/simple-text/SimpleText.astro";
import Form from "@forms/form/Form.astro";

const {
  eyebrow = "Eyebrow Heading",
  heading = "Contact us",
  description = "",
  formFields = [],
  formAction = "/",

  colorScheme = "inherit",
  backgroundColor,
  class: className,
  useDefaultEditableBinding = false,
  _component,
  ...htmlAttributes
} = Astro.props;
---

<CustomSection
  class:list={["centre-form", className]}
  maxContentWidth="lg"
  paddingHorizontal="xl"
  paddingVertical="4xl"
  colorScheme={colorScheme}
  backgroundColor={backgroundColor}
  useDefaultEditableBinding={useDefaultEditableBinding}
  {...htmlAttributes}
>
  <Heading
    level="h3"
    size="xs"
    alignX="center"
    text={eyebrow}
    data-prop="eyebrow"
  />
  <Heading
    level="h2"
    alignX="center"
    text={heading}
    data-prop="heading"
  />
  <SimpleText
    text={description}
    alignX="center"
    size="md"
    data-prop="description"
  />
  <div class="centre-form__form-wrapper">
    <Form
      action={formAction}
      formBlocks={formFields}
      data-children-prop="formFields"
    />
  </div>
</CustomSection>

<style is:global>
  @layer page-sections {
    .centre-form {
      text-align: center;
    }

    .centre-form__form-wrapper {
      max-width: 640px;
      margin-inline: auto;
      margin-top: var(--spacing-xl);
    }

    .centre-form__form-wrapper .form {
      margin-top: 0;
    }

    .centre-form__form-wrapper .input,
    .centre-form__form-wrapper .textarea {
      text-align: start;
    }

    .centre-form__form-wrapper .field {
      background-color: transparent;
    }

    .centre-form__form-wrapper .submit {
      margin-top: var(--spacing-lg);
    }
  }
</style>
