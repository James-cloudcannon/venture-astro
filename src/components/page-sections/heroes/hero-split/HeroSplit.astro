---
import CustomSection from "@builders/custom-section/CustomSection.astro";
import Split from "@wrappers/split/Split.astro";
import Card from "@wrappers/card/Card.astro";
import Heading from "@core-elements/heading/Heading.astro";
import Text from "@core-elements/text/Text.astro";
import ButtonGroup from "@wrappers/button-group/ButtonGroup.astro";
import Image from "@core-elements/image/Image.astro";

const {
  eyebrow = "Eyebrow Heading",
  heading = "Contact us",
  description = "Add some description text to complement the block.",
  buttonText = "Contact us",
  buttonLink = "#",
  image = {},

  colorScheme = "inherit",
  backgroundColor,
  class: className,
  useDefaultEditableBinding = false,
  _component,
  ...htmlAttributes
} = Astro.props;

const buttonSections = [
  {
    _component: "building-blocks/core-elements/button",
    text: buttonText,
    link: buttonLink,
    variant: "tertiary",
    iconName: "arrow-right",
    iconPosition: "after",
    hideText: false,
    size: "md",
  },
];
---

<CustomSection
  class:list={["hero-split", className]}
  paddingVertical="none"
  paddingHorizontal="none"
  colorScheme={colorScheme}
  backgroundColor={backgroundColor}
  useDefaultEditableBinding={useDefaultEditableBinding}
  {...htmlAttributes}
>
  <Split
    distributionMode="half"
    verticalAlignment="stretch"
    gap="none"
    minSplitWidth={0}
  >
    <Card
      slot="first"
      colorScheme="dark"
      backgroundColor="base"
      paddingHorizontal="2xl"
      paddingVertical="2xl"
      class="hero-split__card"
    >
      <Heading
        level="h3"
        size="xs"
        class="hero-split__eyebrow"
        data-prop="eyebrow"
      >
        {eyebrow}
      </Heading>
      <Heading level="h1" size="2xl" data-prop="heading">{heading}</Heading>
      <Text data-prop="description" text={description} />
      <ButtonGroup
        alignX="start"
        buttonSections={buttonSections}
      />
    </Card>
    <Image
      slot="second"
      source={image.source}
      alt={image.alt}
      background={true}
    />
  </Split>
</CustomSection>

<style is:global>
  @layer page-sections {
    .hero-split {
      > .outer-content > .content > .split {
        margin-top: 0;
      }

      .hero-split__card {
        margin-top: 0;

        > .card-inner > .card-outer-content {
          display: flex;
          flex-direction: column;
          justify-content: center;
          min-height: calc(100svh - var(--nav-height));

          > .card-content {
            width: 100%;
          }
        }
      }

      .hero-split__eyebrow {
        > .heading-inner {
          text-transform: uppercase;
          letter-spacing: 4px;
          font-weight: var(--font-weight-semibold);
        }
      }

      .split-inner .pane.second {
        position: relative;
        min-height: 500px;
      }
    }
  }
</style>
