---
import CustomSection from "@builders/custom-section/CustomSection.astro";
import Heading from "@core-elements/heading/Heading.astro";
import SimpleText from "@core-elements/simple-text/SimpleText.astro";
import Video from "@core-elements/video/Video.astro";
import ButtonGroup from "@wrappers/button-group/ButtonGroup.astro";
import Button from "@core-elements/button/Button.astro";

const {
  eyebrow = "",
  heading = "",
  description = "",
  videoType = "youtube",
  videoId = "",
  videoTitle = "",
  buttonText = "",
  buttonLink = "",

  colorScheme = "inherit",
  backgroundColor,
  class: className,
  useDefaultEditableBinding = false,
  _component,
  ...htmlAttributes
} = Astro.props;
---

<CustomSection
  class:list={["feature-large-centre-media", className]}
  maxContentWidth="2xl"
  paddingHorizontal="xl"
  paddingVertical="4xl"
  colorScheme={colorScheme}
  backgroundColor={backgroundColor}
  useDefaultEditableBinding={useDefaultEditableBinding}
  {...htmlAttributes}
>
  <Heading level="h3" size="xs" alignX="center" data-prop="eyebrow" text={eyebrow} />
  <Heading level="h2" alignX="center" data-prop="heading" text={heading} />
  <SimpleText text={description} alignX="center" size="md" data-prop="description" />
  {videoId && (
    <Video type={videoType} id={videoId} title={videoTitle} />
  )}
  {buttonText && (
    <ButtonGroup alignX="center">
      <Button
        text={buttonText}
        link={buttonLink}
        variant="tertiary"
        iconName="arrow-right"
        iconPosition="after"
        data-prop="buttonText"
      />
    </ButtonGroup>
  )}
</CustomSection>

<style is:global>
  @layer page-sections {
    .feature-large-centre-media {
      text-align: center;
    }

    .feature-large-centre-media .heading {
      text-wrap: balance;
    }

    .feature-large-centre-media .video {
      width: 100%;
      border-radius: var(--radius-sm);
    }
  }
</style>
