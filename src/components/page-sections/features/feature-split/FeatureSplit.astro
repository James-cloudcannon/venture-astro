---
import CustomSection from "@builders/custom-section/CustomSection.astro";
import Split from "@wrappers/split/Split.astro";
import Card from "@wrappers/card/Card.astro";
import Heading from "@core-elements/heading/Heading.astro";
import Text from "@core-elements/text/Text.astro";
import ButtonGroup from "@wrappers/button-group/ButtonGroup.astro";
import Image from "@core-elements/image/Image.astro";

const {
  eyebrow = "Tag or label headline",
  heading = "A component to showcase your brand",
  description = "",
  buttonText = "Book now",
  buttonLink = "/booking/",
  image = {},
  reverse = false,

  colorScheme = "inherit",
  backgroundColor,
  class: className,
  useDefaultEditableBinding = false,
  _component,
  ...htmlAttributes
} = Astro.props;

const buttonSections = [
  {
    _component: "building-blocks/core-elements/button",
    text: buttonText,
    link: buttonLink,
    variant: "tertiary",
    iconName: "arrow-right",
    iconPosition: "after",
    hideText: false,
    size: "md",
  },
];
---

<CustomSection
  class:list={["feature-split", className]}
  paddingVertical="none"
  paddingHorizontal="none"
  maxContentWidth="2xl"
  colorScheme={colorScheme}
  backgroundColor={backgroundColor}
  useDefaultEditableBinding={useDefaultEditableBinding}
  {...htmlAttributes}
>
  <Split
    distributionMode="half"
    verticalAlignment="stretch"
    gap="none"
    reverse={reverse}
    minSplitWidth={0}
  >
    <Card
      slot="first"
      colorScheme="dark"
      backgroundColor="base"
      paddingHorizontal="2xl"
      paddingVertical="2xl"
      class="feature-split__card"
    >
      <Heading
        level="h3"
        size="xs"
        class="feature-split__eyebrow"
        data-prop="eyebrow"
      >
        {eyebrow}
      </Heading>
      <Heading level="h2" data-prop="heading">{heading}</Heading>
      <Text data-prop="description" text={description} />
      <ButtonGroup
        alignX="start"
        buttonSections={buttonSections}
      />
    </Card>
    <Image
      slot="second"
      source={image.source}
      alt={image.alt}
      background={true}
    />
  </Split>
</CustomSection>

<style is:global>
  @layer page-sections {
    .feature-split {
      > .outer-content > .content > .split {
        margin-top: 0;
      }

      .feature-split__card {
        margin-top: 0;
        height: 100%;

        > .card-inner {
          height: 100%;
        }

        > .card-inner > .card-outer-content {
          display: flex;
          flex-direction: column;
          justify-content: center;
          min-height: 550px;
          height: 100%;

          > .card-content {
            width: 100%;
          }
        }
      }

      .feature-split__eyebrow {
        > .heading-inner {
          text-transform: uppercase;
          letter-spacing: 4px;
          font-weight: var(--font-weight-semibold);
        }
      }

      .split-inner .pane {
        &.first, &.second {
          position: relative;
          min-height: 550px;
        }
      }
    }
  }
</style>
