---
import CustomSection from "@builders/custom-section/CustomSection.astro";
import Heading from "@core-elements/heading/Heading.astro";
import SimpleText from "@core-elements/simple-text/SimpleText.astro";
import Icon from "@core-elements/icon/Icon.astro";
import Text from "@core-elements/text/Text.astro";
import Card from "@wrappers/card/Card.astro";
import ButtonGroup from "@wrappers/button-group/ButtonGroup.astro";

const {
  eyebrow = "",
  heading = "",
  description = "",
  cards = [],
  buttonSections = [],

  colorScheme = "inherit",
  backgroundColor,
  class: className,
  useDefaultEditableBinding = false,
  _component,
  ...htmlAttributes
} = Astro.props;
---

<CustomSection
  class:list={["feature-icon-card-grid", className]}
  maxContentWidth="2xl"
  paddingHorizontal="xl"
  paddingVertical="4xl"
  colorScheme={colorScheme}
  backgroundColor={backgroundColor}
  useDefaultEditableBinding={useDefaultEditableBinding}
  {...htmlAttributes}
>
  <Heading level="h3" size="xs" alignX="center" data-prop="eyebrow" text={eyebrow} />
  <Heading level="h2" alignX="center" data-prop="heading" text={heading} />
  <SimpleText text={description} alignX="center" size="lg" data-prop="description" />

  <div class="feature-icon-card-grid__grid" data-editable="array" data-prop="cards">
    {cards.map((card) => (
      <div class="feature-icon-card-grid__item" data-editable="array-item" data-id="page-sections/features/feature-icon-card-grid/cardItem">
        <Card colorScheme="dark" backgroundColor="base" rounded={false} border={false} paddingHorizontal="lg" paddingVertical="lg">
          <Icon name={card.iconName} size="2xl" />
          <Heading level="h4" size="xs" text={card.cardEyebrow} data-prop="cardEyebrow" />
          <Heading level="h3" size="md" text={card.cardHeading} data-prop="cardHeading" />
          <Text text={card.cardDescription} data-prop="cardDescription" />
        </Card>
      </div>
    ))}
  </div>

  <ButtonGroup
    alignX="center"
    buttonSections={buttonSections}
    data-children-prop="buttonSections"
  />
</CustomSection>

<style is:global>
  @layer page-sections {
    .feature-icon-card-grid__grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: var(--spacing-md);
      width: 100%;
      margin-top: var(--spacing-xl);
    }

    .feature-icon-card-grid__item > .card {
      margin-top: 0;
    }

    .feature-icon-card-grid__item .heading .heading-inner.size-xs {
      text-transform: uppercase;
      letter-spacing: 0.15em;
    }

    @media (max-width: 768px) {
      .feature-icon-card-grid__grid {
        grid-template-columns: 1fr;
        max-width: 400px;
        margin-inline: auto;
      }
    }
  }
</style>
