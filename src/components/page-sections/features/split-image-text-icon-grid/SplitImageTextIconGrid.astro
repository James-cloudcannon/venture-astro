---
import CustomSection from "@builders/custom-section/CustomSection.astro";
import Split from "@wrappers/split/Split.astro";
import Card from "@wrappers/card/Card.astro";
import Heading from "@core-elements/heading/Heading.astro";
import Icon from "@core-elements/icon/Icon.astro";
import SimpleText from "@core-elements/simple-text/SimpleText.astro";
import ButtonGroup from "@wrappers/button-group/ButtonGroup.astro";
import Image from "@core-elements/image/Image.astro";

const {
  eyebrow = "Let your features shine",
  heading = "A featured icons block",
  items = [],
  buttonText = "Book Now",
  buttonLink = "/booking/",
  image = {},

  colorScheme = "inherit",
  backgroundColor,
  class: className,
  useDefaultEditableBinding = false,
  _component,
  ...htmlAttributes
} = Astro.props;

const buttonSections = [
  {
    _component: "building-blocks/core-elements/button",
    text: buttonText,
    link: buttonLink,
    variant: "tertiary",
    iconName: "arrow-right",
    iconPosition: "after",
    hideText: false,
    size: "md",
  },
];
---

<CustomSection
  class:list={["split-image-text-icon-grid", className]}
  paddingVertical="none"
  paddingHorizontal="none"
  maxContentWidth="2xl"
  colorScheme={colorScheme}
  backgroundColor={backgroundColor}
  useDefaultEditableBinding={useDefaultEditableBinding}
  {...htmlAttributes}
>
  <Split
    distributionMode="half"
    verticalAlignment="stretch"
    gap="none"
    minSplitWidth={0}
  >
    <Card
      slot="first"
      colorScheme="dark"
      backgroundColor="base"
      paddingHorizontal="2xl"
      paddingVertical="2xl"
      class="split-image-text-icon-grid__card"
    >
      <Heading
        level="h3"
        size="xs"
        class="split-image-text-icon-grid__eyebrow"
        data-prop="eyebrow"
      >
        {eyebrow}
      </Heading>
      <Heading level="h2" data-prop="heading">{heading}</Heading>
      <div
        class="split-image-text-icon-grid__items"
        data-editable="array"
        data-prop="items"
      >
        {items.map((item) => (
          <div
            class="split-image-text-icon-grid__item"
            data-editable="array-item"
            data-id="page-sections/features/split-image-text-icon-grid/featureItem"
          >
            <div class="split-image-text-icon-grid__icon-wrapper">
              <Icon name={item.iconName} size="2xl" alignX="center" />
            </div>
            <SimpleText text={item.label} alignX="center" size="sm" />
          </div>
        ))}
      </div>
      <ButtonGroup
        alignX="start"
        buttonSections={buttonSections}
      />
    </Card>
    <Image
      slot="second"
      source={image.source}
      alt={image.alt}
      background={true}
    />
  </Split>
</CustomSection>

<style is:global>
  @layer page-sections {
    .split-image-text-icon-grid {
      > .outer-content > .content > .split {
        margin-top: 0;
      }

      .split-image-text-icon-grid__card {
        margin-top: 0;

        > .card-inner > .card-outer-content {
          display: flex;
          flex-direction: column;
          justify-content: center;
          min-height: 400px;

          > .card-content {
            width: 100%;
          }
        }
      }

      .split-image-text-icon-grid__eyebrow {
        > .heading-inner {
          text-transform: uppercase;
          letter-spacing: 4px;
          font-weight: var(--font-weight-semibold);
        }
      }

      .split-image-text-icon-grid__items {
        display: flex;
        flex-wrap: wrap;
        gap: var(--spacing-xl);
        margin-top: var(--spacing-lg);
      }

      .split-image-text-icon-grid__item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--spacing-sm);
        flex: 0 0 auto;
        min-width: 80px;
        max-width: 120px;

        .simple-text {
          margin-top: 0;
        }
      }

      .split-image-text-icon-grid__icon-wrapper {
        border: 1px solid var(--color-text);
        border-radius: 9999px;
        padding: 0.75em;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .split-inner .pane.second {
        position: relative;
        min-height: 400px;
      }
    }
  }
</style>
